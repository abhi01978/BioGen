<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Book a Test</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center p-4">
  <div class="bg-white shadow-lg rounded-lg w-full max-w-2xl p-8">
    <h2 class="text-2xl font-bold text-blue-700 mb-6 text-center">Book a Medical Test</h2>

    <form action="https://formsubmit.co/YOUR_EMAIL_HERE" method="POST" class="space-y-5">
      <!-- Replace YOUR_EMAIL_HERE with your real email -->

      <!-- Name -->
      <div>
        <label class="block text-gray-700 font-medium mb-1" for="name">Full Name <span class="text-red-500">*</span></label>
        <input type="text" id="name" name="name" required
          class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
      </div>

      <!-- Phone -->
      <div>
        <label class="block text-gray-700 font-medium mb-1" for="phone">Phone Number <span class="text-red-500">*</span></label>
        <input type="tel" id="phone" name="phone" required pattern="[0-9]{10,15}" placeholder="e.g. 9876543210"
          class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
      </div>

      <!-- Email -->
      <div>
        <label class="block text-gray-700 font-medium mb-1" for="email">Email Address</label>
        <input type="email" id="email" name="email"
          class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
      </div>

      <!-- Test Name -->
      <div>
        <label class="block text-gray-700 font-medium mb-1" for="test">Test Name <span class="text-red-500">*</span></label>
        <input type="text" id="test" name="test_name" required
          class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
      </div>

      <!-- Preferred Date -->
      <div>
        <label class="block text-gray-700 font-medium mb-1" for="date">Preferred Test Date</label>
        <input type="date" id="date" name="preferred_date"
          class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
      </div>

      <!-- Notes -->
      <div>
        <label class="block text-gray-700 font-medium mb-1" for="notes">Additional Notes (Optional)</label>
        <textarea id="notes" name="notes" rows="3"
          class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
      </div>

      <!-- Hidden settings for FormSubmit -->
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_subject" value="New Test Booking Request" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_next" value="https://yourwebsite.com/thank-you.html" />

      <!-- Submit -->
      <button type="submit"
        class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-200 text-lg font-semibold">
        Book Test
      </button>
    </form>
  </div>
</body>
</html>
